// Test the http namespace against public test APIs

async fn main() {
  print(bold("Testing Tova HTTP Client"))
  print(repeat("=", 40))

  // ── Test 1: GET request with JSON response ──────────────
  print("\n" + cyan("Test 1: http.get() — JSON endpoint"))
  var result = await http.get("https://jsonplaceholder.typicode.com/posts/1")
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      print("  OK: " + to_string(resp.ok))
      print("  Title: " + resp.body.title)
      assert(resp.status == 200, "Expected 200")
      assert(resp.ok == true, "Expected ok")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 2: GET with query params ────────────────────────
  print("\n" + cyan("Test 2: http.get() — with query params"))
  result = await http.get("https://jsonplaceholder.typicode.com/posts", {
    params: { userId: 1, _limit: 3 }
  })
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      print("  Results count: " + to_string(len(resp.body)))
      assert(resp.status == 200, "Expected 200")
      assert(len(resp.body) == 3, "Expected 3 results")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 3: POST with JSON body ──────────────────────────
  print("\n" + cyan("Test 3: http.post() — JSON body"))
  result = await http.post("https://jsonplaceholder.typicode.com/posts", {
    title: "Tova HTTP Test",
    body: "Testing the http namespace",
    userId: 1
  })
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      print("  Created ID: " + to_string(resp.body.id))
      assert(resp.status == 201, "Expected 201 Created")
      assert(resp.body.title == "Tova HTTP Test", "Expected title match")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 4: PUT request ──────────────────────────────────
  print("\n" + cyan("Test 4: http.put() — update resource"))
  result = await http.put("https://jsonplaceholder.typicode.com/posts/1", {
    id: 1,
    title: "Updated Title",
    body: "Updated body",
    userId: 1
  })
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      print("  Updated title: " + resp.body.title)
      assert(resp.status == 200, "Expected 200")
      assert(resp.body.title == "Updated Title", "Expected updated title")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 5: PATCH request ────────────────────────────────
  print("\n" + cyan("Test 5: http.patch() — partial update"))
  result = await http.patch("https://jsonplaceholder.typicode.com/posts/1", {
    title: "Patched Title"
  })
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      print("  Patched title: " + resp.body.title)
      assert(resp.status == 200, "Expected 200")
      assert(resp.body.title == "Patched Title", "Expected patched title")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 6: DELETE request ───────────────────────────────
  print("\n" + cyan("Test 6: http.delete()"))
  result = await http.delete("https://jsonplaceholder.typicode.com/posts/1")
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      assert(resp.status == 200, "Expected 200")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 7: HEAD request ─────────────────────────────────
  print("\n" + cyan("Test 7: http.head()"))
  result = await http.head("https://jsonplaceholder.typicode.com/posts/1")
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      assert(resp.status == 200, "Expected 200")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 8: Non-200 status (404) ─────────────────────────
  print("\n" + cyan("Test 8: http.get() — 404 returns Ok with ok:false"))
  result = await http.get("https://jsonplaceholder.typicode.com/posts/99999")
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      print("  OK: " + to_string(resp.ok))
      assert(resp.status == 404, "Expected 404")
      assert(resp.ok == false, "Expected ok to be false")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 9: Response headers ─────────────────────────────
  print("\n" + cyan("Test 9: Response headers accessible"))
  result = await http.get("https://jsonplaceholder.typicode.com/posts/1")
  match result {
    Ok(resp) => {
      var ct = resp.headers["content-type"]
      print("  Content-Type: " + ct)
      assert(contains(ct, "json"), "Expected JSON content type")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 10: Connection error ────────────────────────────
  print("\n" + cyan("Test 10: Connection error returns Err"))
  result = await http.get("http://localhost:1")
  match result {
    Ok(_) => print(red("  FAILED: Should have errored"))
    Err(e) => {
      print("  Error: " + e)
      print(green("  PASSED (got Err as expected)"))
    }
  }

  // ── Test 11: json() method on response ───────────────────
  print("\n" + cyan("Test 11: resp.json() method"))
  result = await http.get("https://jsonplaceholder.typicode.com/posts/1")
  match result {
    Ok(resp) => {
      var json_result = resp.json()
      match json_result {
        Ok(data) => {
          print("  json().userId: " + to_string(data.userId))
          assert(data.userId == 1, "Expected userId 1")
          print(green("  PASSED"))
        }
        Err(e) => print(red("  FAILED json parse: " + e))
      }
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  // ── Test 12: Streaming response ──────────────────────────
  print("\n" + cyan("Test 12: http.get_stream()"))
  result = await http.get_stream("https://jsonplaceholder.typicode.com/posts")
  match result {
    Ok(resp) => {
      print("  Status: " + to_string(resp.status))
      print("  Has body stream: " + to_string(resp.body != nil))
      assert(resp.status == 200, "Expected 200")
      print(green("  PASSED"))
    }
    Err(e) => print(red("  FAILED: " + e))
  }

  print("\n" + repeat("=", 40))
  print(bold(green("All HTTP client tests complete!")))
}

main()
