// Test chained comparisons
age = 25
if 18 <= age <= 65 {
  print("chained works")
}

// Test index_of null comparison
pos = index_of("hello", "xyz")
print(pos)
print(pos == null)
print(pos < 0)

// Check is_numeric for digit checking
print(is_numeric("5"))
print(is_numeric("a"))

// Test Option .filter
o = Some(5)
print(o.filter(fn(x) x > 3))

// Test None piped printing
n = None
print(n.isSome())
print(n.isNone())

// Check if words() exists
ws = words("hello world foo")
print(ws)
