// Test entries format
obj = { a: 1, b: 2 }
for entry in entries(obj) {
  print(entry)
  print(type_of(entry))
}

// Test reduce argument order
nums = [1, 2, 3, 4, 5]
total = reduce(nums, fn(acc, x) acc + x, 0)
print("reduce: {total}")

// Test piped reduce
total2 = nums |> reduce(fn(acc, x) acc + x, 0)
print("piped reduce: {total2}")

// Test sorted
s = sorted([3, 1, 4, 1, 5])
print("sorted: {s}")

// Test sort_by
items = [{name: "b", val: 2}, {name: "a", val: 1}]
s2 = sort_by(items, fn(x) x.val)
print("sort_by: {s2}")

// Test upper/lower
print(upper("hello"))
print(lower("HELLO"))

// Test substr
print(substr("Hello, World!", 0, 5))

// Test reversed
print(reversed([1, 2, 3]))

// Test drop
print(drop([1, 2, 3, 4, 5], 2))

// Test all/any
print(all([1, 2, 3], fn(x) x > 0))
print(any([1, 2, 3], fn(x) x > 2))

// Test sum piped
print([1, 2, 3] |> sum())

// Test chars
print(chars("abc"))
