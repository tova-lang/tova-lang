status = "active"

label = if status == "active" { "ON" } else { "OFF" }
print(label)

priority = 3
urgency = match priority {
  1 => "critical"
  2 => "high"
  3 => "medium"
  _ => "low"
}
print("Priority {priority} is {urgency}")

fn classify(temp) {
  if temp < 0 { "freezing" }
  elif temp < 20 { "cold" }
  elif temp < 30 { "comfortable" }
  else { "hot" }
}

print(classify(15))
print(classify(35))
